# Copy this file to `.env` and fill in your credentials.
#
# Active lines below are settings you should fill in. Commented-out lines fall
# back to the default described in their comment — uncomment and edit only the
# ones you want to change.


# ---- Peppyrus API ----

# Your Peppyrus API key. Required — the app cannot send invoices without it.
PEPPYRUS_API_KEY=your_test_api_key_here

# Your PEPPOL participant ID. For Belgian senders, use the 0208 scheme (CBE
# enterprise number): 0208:0123456789 — no "BE" prefix on the number, no 9925.
PEPPOL_SENDER_ID=0208:0123456789

# Peppyrus base URL. Defaults to the test endpoint when unset.
# Uncomment to send through production:
# PEPPYRUS_BASE_URL=https://api.peppyrus.be/v1


# ---- Web UI login gate ----

# Single-password gate for the web UI. When APP_PASSWORD_HASH is set the gate is
# ON (every page requires the password); when unset the UI is open (and bound to
# loopback by default). Store the HASH, never the plaintext.
#
# The line below is ready to use — its password is "Peppify!". Uncomment it to
# enable the gate, then CHANGE IT to your own: regenerate the line with
#   uv run python -c 'from werkzeug.security import generate_password_hash as g; print("APP_PASSWORD_HASH=" + g("your-password").replace("$", "$$"))'
# The '$' are doubled to '$$' so Docker Compose — which interpolates '$' in .env
# — keeps the hash intact; the app collapses '$$' back to '$', so the same line
# also works for the dev server and gunicorn.
# APP_PASSWORD_HASH=scrypt:32768:8:1$$Sof8jUbgp8YcJOqL$$2ca22a4cf2d14d43db822a38ca5e06fcd51fea7221b3d6265b96e41f0a5ec63bacc14fd0ef6627248df97628b9ccbb21c63486b0d4ddff3cc280ba3172cb11af

# Session signing key. When unset, a random key is generated at startup and you
# are logged out on every restart. Set one for sessions that survive restarts:
#   uv run python -c "import secrets; print(secrets.token_hex(32))"
# SECRET_KEY=


# ---- Network binding ----

# Host-facing bind address. Defaults to 127.0.0.1 (loopback only — not reachable
# from other machines). Uncomment to expose on the LAN — only do this with the
# login gate enabled. Over plain HTTP the password and cookie travel in cleartext,
# so use a TLS-terminating reverse proxy on untrusted networks.
# BIND_HOST=0.0.0.0

# Host-facing port. Defaults to 5000. Uncomment to change it (e.g. to run several
# deployments side by side on one host).
# BIND_PORT=5000

# Mark the session cookie Secure (so it is never sent over plain HTTP). Uncomment
# only when serving behind TLS; leave unset for plain-HTTP LAN use.
# SESSION_COOKIE_SECURE=true

# Docker only: a unique project name per deployment, so multiple stacks on one
# host don't collide on container/volume/network names.
# COMPOSE_PROJECT_NAME=peppify
