# Copy this file to `.env` and fill in your test credentials.
PEPPYRUS_API_KEY=your_test_api_key_here
# Your PEPPOL participant ID. For Belgian senders, use the 0208 scheme (CBE
# enterprise number): 0208:0123456789 — no "BE" prefix on the number, no 9925.
PEPPOL_SENDER_ID=0208:0123456789
# Optional: override base URL for Peppyrus. Defaults to the test endpoint.
# Set to https://api.peppyrus.be/v1 for production.
PEPPYRUS_BASE_URL=https://api.test.peppyrus.be/v1

# ---- Webapp ----
# Optional single-password login gate for the web UI. Setting this enables the
# gate (every page requires the password); leaving it empty keeps the app open,
# loopback-only as before. Store the HASH, never the plaintext.
# Generate a ready-to-paste line (the '$' are doubled to '$$' so Docker Compose,
# which interpolates '$' in .env, keeps the hash intact; the app collapses '$$'
# back to '$', so this same line also works for the dev server and gunicorn):
#   uv run python -c 'from werkzeug.security import generate_password_hash as g; print("APP_PASSWORD_HASH=" + g("your-password").replace("$", "$$"))'
APP_PASSWORD_HASH=
# Session signing key. If empty, a random key is generated at startup and you are
# logged out on every restart. Set one to make sessions persistent. Generate with:
#   uv run python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=
# Host-facing bind address. Default 127.0.0.1 (loopback only — not reachable from
# other machines). Set BIND_HOST=0.0.0.0 to expose on the LAN — only do this with
# APP_PASSWORD_HASH set. Over plain HTTP the password/cookie travel in cleartext;
# use a TLS reverse proxy on untrusted networks.
BIND_HOST=127.0.0.1
BIND_PORT=5000
# Set to true only when serving behind TLS — marks the session cookie Secure so it
# is never sent over plain HTTP. Leave empty for plain-HTTP LAN use (default).
# SESSION_COOKIE_SECURE=
# Docker only: set a unique project name per deployment so multiple stacks on one
# host don't collide on container/volume/network names.
# COMPOSE_PROJECT_NAME=peppify
